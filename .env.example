# Copy to .env and adjust: `cp .env.example .env`
# docker compose reads .env automatically.

# --- Image ---
# Used as the local build tag, or set to a registry image to skip building.
MIRROR_IMAGE=magic-mirror:latest

# --- Ports ---
# Host port mapped to the container's 8080. Change to avoid conflicts.
MIRROR_HOST_PORT=8080

# --- Config mount ---
# Path (host) to your MagicMirror config.js. Must be readable by UID 1000
# (e.g. `chmod 644 volumes/config.js`). Mounted read-only into the container.
MIRROR_CONFIG=./volumes/config.js

# Optional: path to a custom startup script run before the server launches.
# Also uncomment the matching volume line in docker-compose.yml to use it.
# MIRROR_CUSTOM_STARTUP=./volumes/custom-startup.sh

# --- config.js env substitutions (applied via envsubst at startup) ---
MIRROR_ADDRESS=0.0.0.0
MIRROR_PORT=8080

# --- OpenTelemetry (optional) ---
OTEL_SERVICE_NAME=magic-mirror
# Point at your OTLP collector; leave default if you don't collect traces.
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
# Extra headers for OTLP export, e.g. "authorization=Bearer <token>".
OTEL_EXPORTER_OTLP_HEADERS=
